{
  "name": "canvasquartosync",
  "displayName": "Canvas Quarto Sync",
  "description": "Write courses in Quarto, preview live, sync to Canvas in one click.",
  "version": "0.1.0",
  "publisher": "JonssonLogic",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Education",
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:config.toml"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cqs.syncToCanvas",
        "title": "Sync to Canvas",
        "category": "Canvas Quarto Sync",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "cqs.openPreview",
        "title": "Open QMD Preview",
        "category": "Canvas Quarto Sync",
        "icon": "$(open-preview)"
      },
      {
        "command": "cqs.initCourse",
        "title": "Initialize Course",
        "category": "Canvas Quarto Sync"
      },
      {
        "command": "cqs.importFromCanvas",
        "title": "Import from Canvas",
        "category": "Canvas Quarto Sync"
      },
      {
        "command": "cqs.diffWithCanvas",
        "title": "Diff with Canvas",
        "category": "Canvas Quarto Sync"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "resourceExtname == .qmd",
          "command": "cqs.openPreview",
          "group": "navigation"
        }
      ]
    },
    "languages": [
      {
        "id": "quarto",
        "extensions": [
          ".qmd"
        ],
        "aliases": [
          "Quarto"
        ]
      }
    ],
    "configuration": {
      "title": "Canvas Quarto Sync",
      "properties": {
        "cqs.pythonVenvPath": {
          "type": "string",
          "default": "",
          "description": "Path to the Python virtual environment for CanvasQuartoSync. Leave empty for auto-detection."
        },
        "cqs.autoPreviewOnOpen": {
          "type": "boolean",
          "default": false,
          "description": "Automatically open the QMD preview when a .qmd file is opened."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "npm run build:extension && npm run build:webview",
    "build:extension": "node esbuild.mjs --production",
    "build:webview": "vite build",
    "watch": "concurrently \"node esbuild.mjs --watch\" \"vite build --watch\"",
    "watch:extension": "node esbuild.mjs --watch",
    "lint": "eslint src/ webview/",
    "test": "vscode-test",
    "package": "vsce package"
  },
  "dependencies": {
    "@iarna/toml": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.0",
    "esbuild": "^0.21.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "katex": "^0.16.0",
    "mermaid": "^11.0.0",
    "unified": "^11.0.0",
    "remark-parse": "^11.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "remark-directive": "^3.0.0",
    "remark-rehype": "^11.0.0",
    "rehype-katex": "^7.0.0",
    "rehype-highlight": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-raw": "^7.0.0",
    "rehype-react": "^8.0.0",
    "react-markdown": "^9.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0"
  }
}
