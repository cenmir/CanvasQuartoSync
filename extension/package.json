{
  "name": "canvasquartosync",
  "displayName": "Canvas Quarto Sync",
  "description": "Write courses in Quarto, preview live, sync to Canvas in one click.",
  "version": "0.2.1",
  "publisher": "KalleMirza",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cenmir/CanvasQuartoSync"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Education",
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:config.toml"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cqs-sidebar",
          "title": "Canvas Quarto Sync",
          "icon": "$(mortar-board)"
        }
      ]
    },
    "views": {
      "cqs-sidebar": [
        {
          "id": "cqs.projectActions",
          "name": "Project"
        },
        {
          "id": "cqs.syncActions",
          "name": "Sync"
        },
        {
          "id": "cqs.toolActions",
          "name": "Tools"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "cqs.projectActions",
        "contents": "No course project detected.\n[New Project](command:cqs.newProject)\n[Open Folder](command:vscode.openFolder)",
        "when": "!cqs.hasCourseProject"
      }
    ],
    "commands": [
      {
        "command": "cqs.newProject",
        "title": "New Project",
        "category": "Canvas Quarto Sync",
        "icon": "$(add)"
      },
      {
        "command": "cqs.syncToCanvas",
        "title": "Sync to Canvas",
        "category": "Canvas Quarto Sync",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "cqs.syncFile",
        "title": "Sync This File to Canvas",
        "category": "Canvas Quarto Sync",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "cqs.openPreview",
        "title": "Open QMD Preview",
        "category": "Canvas Quarto Sync",
        "icon": "$(open-preview)"
      },
      {
        "command": "cqs.initCourse",
        "title": "Initialize Course",
        "category": "Canvas Quarto Sync"
      },
      {
        "command": "cqs.importFromCanvas",
        "title": "Import from Canvas",
        "category": "Canvas Quarto Sync"
      },
      {
        "command": "cqs.diffWithCanvas",
        "title": "Diff with Canvas",
        "category": "Canvas Quarto Sync"
      },
      {
        "command": "cqs.purgeCourse",
        "title": "Purge Canvas Course",
        "category": "Canvas Quarto Sync",
        "icon": "$(trash)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "resourceExtname == .qmd",
          "command": "cqs.syncFile",
          "group": "navigation"
        },
        {
          "when": "resourceExtname == .qmd",
          "command": "cqs.openPreview",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "when": "resourceExtname == .qmd",
          "command": "cqs.syncFile",
          "group": "cqs@1"
        },
        {
          "when": "resourceExtname == .qmd",
          "command": "cqs.syncToCanvas",
          "group": "cqs@2"
        }
      ],
      "explorer/context": [
        {
          "when": "resourceExtname == .qmd",
          "command": "cqs.syncFile",
          "group": "cqs@1"
        }
      ]
    },
    "languages": [
      {
        "id": "quarto",
        "extensions": [
          ".qmd"
        ],
        "aliases": [
          "Quarto"
        ]
      }
    ],
    "configuration": {
      "title": "Canvas Quarto Sync",
      "properties": {
        "cqs.pythonVenvPath": {
          "type": "string",
          "default": "",
          "description": "Path to the Python virtual environment for CanvasQuartoSync. Leave empty for auto-detection."
        },
        "cqs.autoPreviewOnOpen": {
          "type": "boolean",
          "default": false,
          "description": "Automatically open the QMD preview when a .qmd file is opened."
        }
      }
    },
    "walkthroughs": [
      {
        "id": "cqs.gettingStarted",
        "title": "Getting Started with Canvas Quarto Sync",
        "description": "Set up your first course project and sync to Canvas.",
        "steps": [
          {
            "id": "createProject",
            "title": "Create a Course Project",
            "description": "Click the graduation cap in the sidebar, then \"New Project\" to set up your course.\n[Create New Project](command:cqs.newProject)",
            "media": { "markdown": "Fill in your course name, Canvas ID, and API token." }
          },
          {
            "id": "editConfig",
            "title": "Configure Canvas Connection",
            "description": "Open config.toml and set your Canvas course ID and API token path.\n[Open config.toml](command:cqs.openConfig)",
            "media": { "markdown": "The course ID is the number in your Canvas course URL." }
          },
          {
            "id": "writeContent",
            "title": "Write Course Content",
            "description": "Create `.qmd` files with YAML frontmatter. Use `canvas.type` to specify page, assignment, or quiz.",
            "media": { "markdown": "See the study guide template for an example of frontmatter and content structure." }
          },
          {
            "id": "preview",
            "title": "Preview Your Content",
            "description": "Open a `.qmd` file and click the preview icon to see how it will look on Canvas.\n[Open Preview](command:cqs.openPreview)",
            "media": { "markdown": "The preview updates live as you type." }
          },
          {
            "id": "sync",
            "title": "Sync to Canvas",
            "description": "Click \"Sync to Canvas\" in the status bar to push your content to Canvas.\n[Sync Now](command:cqs.syncToCanvas)",
            "media": { "markdown": "Use the Force flag if you want to re-render everything." }
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "npm run build:extension && npm run build:webview",
    "build:extension": "node esbuild.mjs --production",
    "build:webview": "vite build",
    "watch": "concurrently \"node esbuild.mjs --watch\" \"vite build --watch\"",
    "watch:extension": "node esbuild.mjs --watch",
    "lint": "eslint src/ webview/",
    "test": "vscode-test",
    "package": "vsce package"
  },
  "dependencies": {
    "@iarna/toml": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.0",
    "esbuild": "^0.21.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "katex": "^0.16.0",
    "mermaid": "^11.0.0",
    "unified": "^11.0.0",
    "remark-parse": "^11.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "remark-directive": "^3.0.0",
    "remark-rehype": "^11.0.0",
    "rehype-katex": "^7.0.0",
    "rehype-highlight": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-raw": "^7.0.0",
    "rehype-react": "^8.0.0",
    "react-markdown": "^9.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0"
  }
}
